# Fongen environment configuration

# Minecraft body connection
MC_HOST=127.0.0.1
MC_PORT=25565
MC_USERNAME=Fongen
MC_AUTH=offline
MC_VERSION=1.21.4

# Reflex model (fongen-mc = fine-tuned Gemma 4 12B for UMAS action tokens)
# OpenAI-compatible: vLLM, llama-server
# Leave empty to use rule-based SafetyGuard fallback for local testing
REFLEX_MODEL_BASE_URL=http://127.0.0.1:8000/v1
REFLEX_MODEL_API_KEY=fongen-local
REFLEX_MODEL_NAME=fongen-mc

# Planner (LLM-powered strategic brain)
# Works with any OpenAI-compatible API:
#   - Fireworks AI (AMD-hosted Gemma): https://api.fireworks.ai/inference/v1
#   - Google Gemini: https://generativelanguage.googleapis.com/v1beta/openai/
#   - Local vLLM/Ollama: http://127.0.0.1:8000/v1
PLANNER_ENABLED=true
PLANNER_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
PLANNER_API_KEY=your-api-key-here
PLANNER_MODEL=gemini-flash-lite-latest
PLANNER_TEMPERATURE=80
PLANNER_MAX_TOKENS=800

# Chat brain (fast social replies, same key/endpoint)
CHAT_ENABLED=true
CHAT_MODEL=gemini-flash-lite-latest
CHAT_TEMPERATURE=95
CHAT_MAX_TOKENS=200

# Persona
PERSONA_NAME=Fongen
PERSONA_LANG=ru

# Agent loop tuning
PLAN_INTERVAL_MS=45000
MAX_STEPS=50
WATCHDOG_TIMEOUT_MS=60000
OBS_INTERVAL_MS=10000

# Humanizer (anti-robot timings)
HUMANIZE=true
REACT_DELAY_MIN_MS=180
REACT_DELAY_MAX_MS=520
TYPING_CPS=7

# Agent loop tuning
PLAN_INTERVAL_MS=30000
MAX_STEPS=50
WATCHDOG_TIMEOUT_MS=60000

# Logging
LOG_LEVEL=info
